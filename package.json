{
    "name": "nav-enonicxp-frontend",
    "version": "1.2.1",
    "private": true,
    "engines": {
        "node": "24.x"
    },
    "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
    "scripts": {
        "build": "pnpm run build:server && pnpm run build:nextjs",
        "build:nextjs": "pnpm --filter ./packages/nextjs run build",
        "build:server": "pnpm --filter ./packages/server run build",
        "build:storybook": "pnpm --filter ./packages/nextjs run build:storybook",
        "start": "pnpm --filter ./packages/server run start",
        "start-in-docker": "node -r dotenv/config server/.dist/server.cjs dotenv_config_path=./.env",
        "storybook": "pnpm --filter ./packages/nextjs run storybook",
        "dev": "pnpm run copy-env-development && rm -fr packages/nextjs/.next && pnpm run build:server && pnpm run start",
        "dev-custom": "pnpm run copy-env-development-custom && pnpm run build:server && pnpm run start",
        "build-test-production": "pnpm run copy-env-prod-local && pnpm run build",
        "start-test-production": "pnpm run copy-env-prod-local && pnpm run start",
        "start-local": "rm -fr packages/nextjs/.next && pnpm run build-test-production && pnpm run start-test-production",
        "build-and-push-dev-failover": "sh -c 'for a in \"$@\"; do case $a in --app_env=*) APP_ENV=${a#*=};; --image_tag=*) IMAGE_TAG=${a#*=};; esac; done; sh .failover/build-dev-failover-image.sh \"$APP_ENV\" \"$IMAGE_TAG\"' --",
        "analyze-bundle": "pnpm --filter ./packages/nextjs run analyze-bundle",
        "lint": "pnpm -r --parallel run lint",
        "test": "pnpm -r --parallel run test",
        "copy-env-prod-local": "cp .env.prod-local packages/nextjs/.env && cp .env.prod-local packages/server/.env",
        "copy-env-development": "cp .env.development packages/nextjs/.env && cp .env.development packages/server/.env",
        "copy-env-development-custom": "cp .env.development.local packages/nextjs/.env && cp .env.development.local packages/server/.env",
        "prepare": "test \"$CI\" = \"true\" && exit 0; husky || true"
    },
    "devDependencies": {
        "@eslint/compat": "catalog:",
        "@eslint/js": "catalog:",
        "@next/eslint-plugin-next": "catalog:",
        "@playwright/test": "catalog:",
        "@types/escape-html": "catalog:",
        "@types/express": "catalog:",
        "@types/lodash.debounce": "catalog:",
        "@types/mock-fs": "catalog:",
        "@types/node": "catalog:",
        "@typescript-eslint/eslint-plugin": "catalog:",
        "@typescript-eslint/parser": "catalog:",
        "concurrently": "catalog:",
        "esbuild": "catalog:",
        "eslint": "catalog:",
        "eslint-config-prettier": "catalog:",
        "eslint-plugin-css-modules": "catalog:",
        "eslint-plugin-import": "catalog:",
        "eslint-plugin-no-relative-import-paths": "catalog:",
        "eslint-plugin-prettier": "catalog:",
        "eslint-plugin-react": "catalog:",
        "eslint-plugin-react-hooks": "catalog:",
        "globals": "catalog:",
        "husky": "catalog:",
        "lint-staged": "catalog:",
        "prettier": "catalog:",
        "typescript": "catalog:",
        "typescript-eslint": "catalog:"
    },
    "browserslist": {
        "production": [
            ">0.2% in no",
            "iOS >= 11",
            "safari >= 11",
            "not dead",
            "not op_mini all",
            "not ie 11"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "dependencies": {
        "@navikt/nav-dekoratoren-moduler": "catalog:",
        "@next/bundle-analyzer": "catalog:",
        "domhandler": "catalog:",
        "dotenv": "catalog:",
        "express": "catalog:",
        "express-prom-bundle": "catalog:",
        "lru-cache": "catalog:",
        "pino": "catalog:",
        "pino-pretty": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "react-error-boundary": "catalog:",
        "redis": "catalog:"
    },
    "optionalDependencies": {
        "@esbuild/linux-x64": "catalog:"
    },
    "lint-staged": {
        "packages/nextjs/**/*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "packages/server/**/*.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "packages/shared/**/*.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "**/*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    }
}
