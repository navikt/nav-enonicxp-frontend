{
    "name": "nav-enonicxp-frontend",
    "version": "1.2.1",
    "private": true,
    "engines": {
        "node": "24.x"
    },
    "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a",
    "scripts": {
        "build": "pnpm run build:server && pnpm run build:nextjs",
        "build:nextjs": "pnpm --filter ./packages/nextjs run build",
        "build:server": "pnpm --filter ./packages/server run build",
        "build:storybook": "pnpm --filter ./packages/nextjs run build:storybook",
        "start": "pnpm --filter ./packages/server run start",
        "start-in-docker": "node -r dotenv/config server/.dist/server.cjs dotenv_config_path=./.env",
        "storybook": "pnpm --filter ./packages/nextjs run storybook",
        "dev": "pnpm run copy-env-development && rm -fr packages/nextjs/.next && pnpm run build:server && pnpm run start",
        "dev-custom": "pnpm run copy-env-development-custom && pnpm run build:server && pnpm run start",
        "build-test-production": "pnpm run copy-env-prod-local && pnpm run build",
        "start-test-production": "pnpm run copy-env-prod-local && pnpm run start",
        "start-local": "rm -fr packages/nextjs/.next && pnpm run build-test-production && pnpm run start-test-production",
        "build-and-push-dev-failover": "sh .failover/build-dev-failover-image.sh",
        "analyze-bundle": "pnpm --filter ./packages/nextjs run analyze-bundle",
        "lint": "pnpm -r --parallel run lint",
        "test": "pnpm -r --parallel run test",
        "copy-env-prod-local": "cp .env.prod-local packages/nextjs/.env && cp .env.prod-local packages/server/.env",
        "copy-env-development": "cp .env.development packages/nextjs/.env && cp .env.development packages/server/.env",
        "copy-env-development-custom": "cp .env.development.local packages/nextjs/.env && cp .env.development.local packages/server/.env"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@next/eslint-plugin-next": "catalog:",
        "@types/escape-html": "1.0.4",
        "@types/express": "5.0.6",
        "@types/lodash.debounce": "catalog:",
        "@types/mock-fs": "catalog:",
        "@types/node": "20.14.10",
        "@typescript-eslint/eslint-plugin": "8.54.0",
        "@typescript-eslint/parser": "8.54.0",
        "concurrently": "catalog:",
        "esbuild": "0.27.2",
        "eslint": "9.39.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-css-modules": "2.12.0",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-no-relative-import-paths": "1.6.1",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "6.1.0",
        "globals": "16.4.0",
        "husky": "9.1.7",
        "lint-staged": "16.2.7",
        "prettier": "3.8.1",
        "typescript": "5.9.3",
        "typescript-eslint": "8.54.0"
    },
    "browserslist": {
        "production": [
            ">0.2% in no",
            "iOS >= 11",
            "safari >= 11",
            "not dead",
            "not op_mini all",
            "not ie 11"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "dependencies": {
        "@navikt/nav-dekoratoren-moduler": "3.6.1",
        "@next/bundle-analyzer": "15.5.4",
        "domhandler": "^5.0.3",
        "dotenv": "17.2.3",
        "express": "5.2.1",
        "express-prom-bundle": "8.0.0",
        "lru-cache": "catalog:",
        "pino": "10.3.0",
        "pino-pretty": "13.1.3",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-error-boundary": "6.1.0",
        "redis": "catalog:"
    },
    "optionalDependencies": {
        "@esbuild/linux-x64": "0.27.2"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "core-js-pure",
            "esbuild",
            "protobufjs",
            "sharp",
            "unrs-resolver"
        ]
    },
    "lint-staged": {
        "packages/nextjs/**/*.{js,jsx,ts,tsx}": [
            "cd packages/nextjs && pnpm run lint:fix"
        ],
        "packages/server/**/*.{js,ts}": [
            "cd packages/server && pnpm run lint:fix"
        ],
        "packages/shared/**/*.{js,ts}": [
            "cd packages/shared && pnpm run lint:fix"
        ],
        "**/*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    }
}
