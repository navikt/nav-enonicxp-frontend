{
    "name": "nav-enonicxp-frontend-nextjs",
    "version": "1.2.1",
    "private": true,
    "scripts": {
        "build": "next build",
        "build:storybook": "storybook build",
        "prestorybook": "node playwright/copy-screenshots.js",
        "storybook": "storybook dev -p 6006",
        "analyze-bundle": "ANALYZE_BUNDLE=true pnpm run build",
        "lint": "concurrently --raw --names \"tsc,eslint\" --prefix-colors \"blue,green\" \"pnpm run lint:tsc\" \"pnpm run lint:eslint\"",
        "lint:tsc": "tsc",
        "lint:eslint": "eslint src",
        "test": "TZ=Europe/Oslo jest --testPathIgnorePatterns=server/src"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix --max-warnings=0"
        ],
        "*.{ts,tsx,css,scss}": [
            "prettier --write"
        ]
    },
