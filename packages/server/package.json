{
    "name": "nav-enonicxp-frontend-server",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "build": "node build.mjs",
        "build-watch": "WATCH=true node build.mjs",
        "start": "node -r dotenv/config .dist/server.cjs dotenv_config_path=./.env",
        "nodemon-start": "nodemon -r dotenv/config -w .dist .dist/server.cjs dotenv_config_path=./.env",
        "dev": "pnpm run build && concurrently \"pnpm run build-watch\" \"pnpm run nodemon-start\"",
        "test": "next build __test-utils/next-dummy && NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.mjs",
        "lint": "concurrently --raw --names \"tsc,eslint\" --prefix-colors \"blue,green\" \"pnpm run lint:tsc\" \"pnpm run lint:eslint\"",
        "lint:tsc": "tsc",
        "lint:eslint": "eslint src"
    },
    "nodemonConfig": {
        "delay": 500
    },
    "dependencies": {
        "cookie-parser": "1.4.7",
        "http-terminator": "3.2.0",
        "next": "catalog:",
        "on-headers": "1.1.0",
        "prom-client": "15.1.3"
    },
    "devDependencies": {
        "@types/cookie-parser": "1.4.10",
        "@types/on-headers": "1.0.4",
        "@types/mock-fs": "4.13.4",
        "concurrently": "9.2.1",
        "mock-fs": "5.5.0",
        "nodemon": "3.1.11"
    }
}
